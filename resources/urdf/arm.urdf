<?xml version="1.0"?>
<robot name="adeept_arm">

  <link name="link1">
    <visual>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/> 
      <geometry><mesh filename="package://meshes/link1.stl"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://meshes/link1.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> <axis xyz="0 0 1"/> 
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><mesh filename="package://meshes/link2.stl"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><mesh filename="package://meshes/link2.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="-0.01 0 -0.01" rpy="0 0 0"/> 
    <axis xyz="1 0 0"/> 
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/> 
      <geometry><mesh filename="package://meshes/link3.stl"/></geometry>
    </visual>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.005 0.03 0.06" rpy="0 0 0"/> 
    <axis xyz="1 0 0"/> 
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/> 
      <geometry><mesh filename="package://meshes/link4.stl"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="package://meshes/link4.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link4"/>
    <child link="link5"/> 
    <origin xyz="0.015 -0.042 0.085" rpy="0.45 0 0"/> 
    <axis xyz="0 0 1"/> <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://meshes/link5.stl"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://meshes/link5.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="joint_gripper_left" type="revolute">
    <parent link="link5"/>
    <child link="gripper_left"/> 
    <origin xyz="0.01 -0.005 -0.005" rpy="1 0 -1.5708"/> <axis xyz="1 0 0"/> <limit lower="-0.5" upper="0.5" effort="10" velocity="1"/>
  </joint>

  <link name="gripper_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/> <geometry><mesh filename="package://meshes/gripper-1.stl"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="package://meshes/gripper-1.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>

  <joint name="joint_gripper_right" type="revolute">
    <parent link="link5"/>
    <child link="gripper_right"/> 
    <origin xyz="-0.01 -0.005 -0.005" rpy="2.1 0 -1.5708"/> <axis xyz="1 0 0"/> <limit lower="-0.5" upper="0.5" effort="10" velocity="1"/>
  </joint>

  <link name="gripper_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/> <geometry><mesh filename="package://meshes/gripper-2.stl"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><mesh filename="package://meshes/gripper-2.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.02"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>

</robot>